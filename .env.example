# Required — get your API key at https://www.openxbl.com/ (free, 150 req/hour)
OPENXBL_API_KEY=your_openxbl_api_key_here

# Optional — auto-resolved from /account on startup if not set
# XBOX_XUID=your_xuid_here
# XBOX_GAMERTAG=YourGamertag

# Optional — Sentry error tracking DSN
# SENTRY_DSN=

# Optional — log format: "json" or "text" (default: text)
# LOG_FORMAT=text

# Optional — log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=INFO

# Optional — enable CSS hot-rebuild on file changes during development
# XBOX_DEV=1
